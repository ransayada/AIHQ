{
  "name": "@aihq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file .env src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aihq/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "@clerk/backend": "^1.16.4",
    "@elastic/elasticsearch": "^9.3.4",
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.6.0",
    "@hono/zod-validator": "^0.4.2",
    "@prisma/client": "^6.2.1",
    "@sentry/node": "^10.42.0",
    "hono": "^4.6.20",
    "ioredis": "^5.4.2",
    "stripe": "^17.4.0",
    "svix": "^1.86.0",
    "winston": "^3.19.0",
    "winston-elasticsearch": "^0.19.0",
    "ws": "^8.19.0",
    "yjs": "^13.6.29",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
