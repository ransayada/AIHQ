    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.469.0",
    "storybook": "8.6.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
