# =============================================
# AIHQ Environment Variables
# Copy to .env.local for local development
# =============================================

# ----- Clerk Authentication -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ----- Database (Railway PostgreSQL) -----
DATABASE_URL=postgresql://postgres:password@localhost:5432/aihq
DIRECT_URL=postgresql://postgres:password@localhost:5432/aihq

# ----- Redis (Railway Redis) -----
REDIS_URL=redis://localhost:6379

# ----- Stripe Billing -----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx
STRIPE_STUDIO_PRICE_ID=price_xxxx

# ----- Anthropic / Claude API -----
ANTHROPIC_API_KEY=sk-ant-xxxx

# ----- Cloudflare R2 Storage -----
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=aihq-samples
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ----- App URLs -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# ----- Internal -----
INTERNAL_WEBHOOK_SECRET=your-secret-here
NODE_ENV=development
